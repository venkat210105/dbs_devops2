
# Universal Feedback System - Environment Variables Example
# Copy this file to .env and fill in your secrets/config for Render or Docker Compose

# --- Database Configuration (optional overrides) ---
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_PORT=3306

# Ports
BACKEND_PORT=8085
FRONTEND_PORT=3000
ML_SERVICE_PORT=5000
CHATBOT_PORT=4002
CHATBOT_HF_PORT=5001

# Spring profile
SPRING_PROFILE=docker

# Email SMTP (for notifications)
SMTP_USERNAME=
SMTP_PASSWORD=

# Google OAuth/Email settings
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Frontend base URL for deep links in emails
APP_UI_BASE_URL=http://localhost:3000

# Orchestrator/Chatbot (if used)
REACT_APP_BACKEND_URL=http://localhost:8085
REACT_APP_CHATBOT_URL=http://localhost:4002
REACT_APP_ML_SERVICE_URL=http://localhost:5000

# --- Other ---
DATA_PATH=./docker-data/mysql
COMPOSE_PROJECT_NAME=universal-feedback-system