
# DBS Feedback System - Environment Variables Example
# Copy this file to .env and fill in your secrets/config for Render or Docker Compose

# --- Database Configuration ---
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_DATABASE=dbs_feedback
MYSQL_USER=dbsuser
MYSQL_PASSWORD=your_mysql_user_password
MYSQL_PORT=3306

# --- Backend (Spring Boot) ---
BACKEND_PORT=8085
SPRING_PROFILE=prod
SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/dbs_feedback
SPRING_DATASOURCE_USERNAME=dbsuser
SPRING_DATASOURCE_PASSWORD=your_mysql_user_password

# Email SMTP (for notifications)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_app_password

# Google OAuth (for calendar integration)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_PROJECT_ID=dbsmeetscheduler
GOOGLE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_REDIRECT_URI=https://your-backend-url/feedback/oauth2callback
GOOGLE_JWKS_URI=https://www.googleapis.com/oauth2/v3/certs
GOOGLE_ISSUER=https://accounts.google.com

# --- Frontend ---
FRONTEND_PORT=3000
REACT_APP_BACKEND_URL=https://your-backend-url
REACT_APP_CHATBOT_URL=https://your-chatbot-url

# --- Chatbot (Node.js) ---
CHATBOT_PORT=4000
OPENAI_API_KEY=your-openai-api-key
FRONTEND_URL=https://your-frontend-url

# --- ML Service (Python/FastAPI) ---
ML_SERVICE_PORT=5000

# --- Other ---
DATA_PATH=./docker-data/mysql
COMPOSE_PROJECT_NAME=dbs-feedback-system